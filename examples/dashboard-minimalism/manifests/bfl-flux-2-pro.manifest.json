{
  "$schema": "https://mosvera.io/schema/0.1/capability-manifest",
  "provider": "bfl-flux-2-pro",
  "adapter_version": "0.1.0",
  "constructs": {
    "subject": { "lowering_action": "native" },
    "medium": { "lowering_action": "approximate", "note": "Folded into prompt." },
