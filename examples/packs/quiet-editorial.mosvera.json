          "headline": "Aesthetic infrastructure you can inspect."
        }
      }
    },
    "palettes": {},
    "modifiers": {},
    "compositions": {
      "quiet-editorial": {
        "$schema": "https://mosvera.io/schema/0.1/composition",
        "base": "quiet-editorial-base",
        "id": "quiet-editorial"
      }
    }
