          "accent": "#bd5838",
          "accent_2": "#2e6b5f",
          "background": "#f7f2e7",
          "border": "#d8c8b6",
          "code_bg": "#181513",
          "code_ink": "#f5ebdd",
          "ink": "#211b16",
          "muted": "#665c50",
          "surface": "#fffaf0",
          "surface_alt": "#eee3d4"
