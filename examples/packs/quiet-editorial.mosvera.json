{
  "$schema": "https://mosvera.io/schema/0.1/aesthetic-pack",
  "kind": "mosvera.aesthetic_pack",
  "version": "0.1",
  "id": "quiet-editorial",
  "entrypoint": {
    "kind": "composition",
    "id": "quiet-editorial"
  },
  "documents": {
    "templates": {
      "quiet-editorial-base": {
        "$schema": "https://mosvera.io/schema/0.1/template",
        "id": "quiet-editorial-base",
        "imagery": {
          "alt": "Warm paper-toned Mosvera tesserae arranged as a calm editorial composition.",
          "blend": "normal",
          "contrast": "1.02",
          "saturation": "0.92",
          "src": "/assets/aesthetics/hero-quiet-editorial.webp",
          "treatment": "paper_field"
        },
        "layout": {
          "density": "comfortable",
          "max_width": "1160px",
          "radius": "6px",
          "shadow": "0 18px 55px rgba(58, 38, 21, 0.16)"
