{
  "id": "0017-required-unsupported-error",
  "description": "A required construct the adapter marks unsupported is a hard compile error before any provider call.",
  "mep": "MEP-0003",
  "rule": "compile/required-unsupported-errors",
  "kind": "compilation",
  "manifest": {
    "provider": "p",
    "adapter_version": "1",
    "constructs": {
      "subject": {
        "lowering_action": "native"
      }
    }
  },
  "canonical": {
    "subject": "a lighthouse",
    "accent": "#c0563a"
  },
  "criticality": {
    "accent": "required"
  },
  "expect": {
    "status": "error",
    "error": "required_unsupported",
    "construct": "accent"
  }
}
