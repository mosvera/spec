{
  "id": "0021-required-approximate-warns",
  "description": "A required construct that is approximate (not unsupported) compiles with a warning, not an error.",
  "mep": "MEP-0003",
  "rule": "compile/required-approximate-warns-not-errors",
  "kind": "compilation",
  "manifest": {
    "provider": "p",
    "adapter_version": "1",
    "constructs": {
